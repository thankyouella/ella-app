# ─── Supabase (base de datos + autenticación) ───────────────────────────────
# Crea tu proyecto en: https://supabase.com
# Settings → API → copia Project URL y anon/public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Anthropic Claude API ───────────────────────────────────────────────────
# Obtén tu key en: https://console.anthropic.com
VITE_CLAUDE_API_KEY=sk-ant-...

# ─── WHOOP OAuth 2.0 ────────────────────────────────────────────────────────
# Regístrate en: https://developer-dashboard.whoop.com
# Client ID — público, seguro en VITE_
VITE_WHOOP_CLIENT_ID=your_whoop_client_id

# Redirect URI — debe coincidir con el Developer Dashboard
# Local:      http://localhost:5173
# Producción: https://tu-dominio.vercel.app
VITE_WHOOP_REDIRECT_URI=http://localhost:5173

# Client Secret — SOLO servidor (Vercel Function /api/whoop-token)
# NUNCA usar prefijo VITE_ aquí
WHOOP_CLIENT_SECRET=your_whoop_client_secret
